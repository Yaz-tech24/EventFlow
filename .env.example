# Copia este ficheiro para backend/.env e preenche os valores

# Porta do servidor
PORT=3000

# Chave secreta JWT — gera uma string aleatória longa para produção:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=SUBSTITUI_ISTO_POR_UMA_CHAVE_ALEATORIA_LONGA

# Ambiente: development | production
NODE_ENV=development

# Origens permitidas no CORS (separadas por vírgula)
# Em produção: apenas o teu domínio, ex: https://eventflow.co.mz
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
